# Directus Authentication
# Copy this file to .env.directus and fill in your values
# DO NOT commit .env.directus to version control

# Option 1: Static Admin Token (Recommended)
# Create in Directus UI: Settings → Access Tokens
# Set role to Administrator, expiration to Never
DIRECTUS_TOKEN=your-static-admin-token-here

# Option 2: Email/Password (Fallback)
# Use if static token is not available
# DIRECTUS_ADMIN_EMAIL=admin@example.com
# DIRECTUS_ADMIN_PASSWORD=your-password

# Directus URL (optional, defaults to http://localhost:8055)
# DIRECTUS_URL=http://localhost:8055
