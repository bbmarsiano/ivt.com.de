# Directus Docker Environment Variables
# Copy this file to directus.env and fill in your values
# DO NOT commit directus.env to version control

# Directus Security Keys
# Generate random strings using: openssl rand -base64 32
# Minimum 32 characters required
# Note: Directus expects KEY and SECRET (not DIRECTUS_KEY/SECRET)
KEY=your-random-key-here-min-32-chars-replace-with-openssl-rand-base64-32
SECRET=your-random-secret-here-min-32-chars-replace-with-openssl-rand-base64-32

# Admin Account
# Set these to your preferred admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!StrongPassword

# Database Password (if required)
# Leave empty if local PostgreSQL doesn't require a password
# Uncomment and set if your local Postgres requires authentication
# DB_PASSWORD=
